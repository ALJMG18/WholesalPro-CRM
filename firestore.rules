rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "emmanueltorresconcha@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (resource == null || request.auth.uid == resource.data.ownerUid);
    }
    
    function isValidLead(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.status is string &&
             data.ownerUid == request.auth.uid;
    }

    function isValidProperty(data) {
      return data.leadId is string &&
             data.ownerUid == request.auth.uid &&
             (data.address is string && data.address.size() < 500) &&
             (data.arv is number) &&
             (data.repairEstimate is number) &&
             (data.askingPrice is number) &&
             (data.mao is number);
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerUid == request.auth.uid;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidLead(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidLead(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Properties
    match /properties/{propertyId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidProperty(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidProperty(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidTask(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Buyers
    match /buyers/{buyerId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
