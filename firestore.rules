rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') || 
         (request.auth.token.email == "emmanueltorresconcha@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (resource == null || request.auth.uid == resource.data.ownerUid);
    }
    
    function isValidLead(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 200 &&
             data.status is string &&
             data.ownerUid == request.auth.uid &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt == null || data.deletedAt is timestamp) &&
             (!('sequenceId' in data) || data.sequenceId is string) &&
             (!('currentStepIndex' in data) || data.currentStepIndex is number) &&
             (!('lastStepRunAt' in data) || data.lastStepRunAt == null || data.lastStepRunAt is timestamp);
    }

    function isValidLeadUpdate(data, currentData) {
      // Allow updating deleted status and other fields as long as ownerUid is unchanged
      return data.ownerUid == currentData.ownerUid &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() < 200)) &&
             (!('status' in data) || (data.status is string)) &&
             (!('deleted' in data) || data.deleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt == null || data.deletedAt is timestamp) &&
             (!('sequenceId' in data) || data.sequenceId is string) &&
             (!('currentStepIndex' in data) || data.currentStepIndex is number) &&
             (!('lastStepRunAt' in data) || data.lastStepRunAt == null || data.lastStepRunAt is timestamp);
    }

    function isValidSequence(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.ownerUid == request.auth.uid &&
             data.steps is list &&
             data.steps.size() < 50;
    }

    function isValidProperty(data) {
      return data.leadId is string &&
             data.ownerUid == request.auth.uid &&
             (data.address is string && data.address.size() < 500) &&
             (data.arv is number) &&
             (data.repairEstimate is number) &&
             (data.askingPrice is number) &&
             (data.mao is number);
    }

    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerUid == request.auth.uid &&
             (!('dueTime' in data) || data.dueTime == null || data.dueTime is string) &&
             (!('notified' in data) || data.notified is bool);
    }

    function isValidTemplate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['email', 'sms'] &&
             data.body is string && data.body.size() > 0 && data.body.size() < 5000 &&
             data.ownerUid == request.auth.uid;
    }

    function isValidActivity(data) {
      return data.type is string &&
             data.description is string && data.description.size() < 1000 &&
             data.ownerUid == request.auth.uid &&
             data.createdAt is timestamp &&
             (!('leadId' in data) || data.leadId == null || data.leadId is string) &&
             (!('leadName' in data) || data.leadName == null || data.leadName is string);
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && 
                    request.resource.data.role == 'client' &&
                    request.resource.data.keys().hasAll(['email', 'displayName', 'createdAt', 'role']);
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOwner(userId) && 
         request.resource.data.role == resource.data.role && // Cannot change own role
         request.resource.data.createdAt == resource.data.createdAt // Cannot change join date
        )
      );
    }

    // Leads
    match /leads/{leadId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidLead(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidLeadUpdate(request.resource.data, resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Properties
    match /properties/{propertyId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidProperty(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidProperty(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidTask(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Buyers
    match /buyers/{buyerId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Templates
    match /templates/{templateId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidTemplate(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidTemplate(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidActivity(request.resource.data);
      allow update: if false; // Activities are immutable
      allow delete: if isAdmin();
    }

    // Sequences
    match /sequences/{sequenceId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidSequence(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidSequence(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
